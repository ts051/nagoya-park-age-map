# Secret values must stay in environment variables or platform secrets.
# This app currently uses public, keyless data sources, so no API key is required.

# Optional overrides for yearly/monthly data updates:
NAGOYA_POPULATION_PAGE_URL=
NAGOYA_POPULATION_AS_OF=
NAGOYA_PARKS_AS_OF=

# Optional future use if a paid map/geocoding provider replaces the keyless defaults:
MAP_TILE_API_KEY=
GEOCODING_API_KEY=
